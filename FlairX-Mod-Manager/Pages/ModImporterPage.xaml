<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FlairX_Mod_Manager.Pages.ModImporterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="8*" MaxWidth="1000"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Stretch">

                <!-- Warning Card -->
                <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="20" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="WarningTitle" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                            <TextBlock x:Name="WarningMessage" TextWrapping="Wrap" FontSize="12" Opacity="0.9"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step 1: Create Categories Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8F1;" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock x:Name="CreateCategoriesTitle" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock x:Name="CreateCategoriesDescription" FontSize="12" Opacity="0.7" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="3" x:Name="CreateCategoriesButton" Click="CreateCategoriesButton_Click" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72A;" FontSize="16"/>
                                <TextBlock x:Name="CreateCategoriesButtonText"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Aliases Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,24">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8AB;" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="AliasesTitle" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="AliasesDescription" FontSize="12" Opacity="0.7" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Category selector + alias input -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      x:Name="AliasCategoryComboBox"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Select category..."/>

                            <TextBox Grid.Column="2"
                                     x:Name="AliasTextBox"
                                     PlaceholderText="Enter alias..."
                                     KeyDown="AliasTextBox_KeyDown"/>

                            <Button Grid.Column="4"
                                    x:Name="AddAliasButton"
                                    Click="AddAliasButton_Click">
                                <TextBlock x:Name="AddAliasButtonText" Text="Add"/>
                            </Button>
                        </Grid>

                        <!-- Aliases tag cloud per category -->
                        <ItemsControl x:Name="AliasesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="6" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="12" Opacity="0.8"/>
                                        <ScrollViewer MaxHeight="200"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Padding="0,0,12,0">
                                            <ItemsControl ItemsSource="{Binding Aliases}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <controls:WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="RemoveAlias_Click"
                                                                Tag="{Binding}"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                HorizontalContentAlignment="Stretch"
                                                                Padding="12,6"
                                                                Margin="0,0,8,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding AliasName}" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text=" | " VerticalAlignment="Center" Opacity="0.5" Margin="4,0"/>
                                                                <FontIcon Grid.Column="2" Glyph="&#xE711;" FontSize="12" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Step 2: Source Folder Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,2">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="SourceFolderLabel" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="SourceFolderPath" FontSize="12" Opacity="0.7" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="3" x:Name="SelectFolderButton" Click="SelectFolderButton_Click" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                                    <TextBlock x:Name="SelectFolderButtonText"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Nested structure checkbox -->
                        <CheckBox x:Name="NestedStructureCheckBox" Checked="NestedStructureCheckBox_Changed" Unchecked="NestedStructureCheckBox_Changed" Margin="36,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="NestedStructureLabel" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="NestedStructureDescription" FontSize="12" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- Scan Button Card -->
                <Border x:Name="StatusCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,24"
                        Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="StatusTitle" FontWeight="SemiBold" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock x:Name="FoundModsLabel" FontSize="12" Opacity="0.7"/>
                                        <TextBlock x:Name="FoundModsCount" Text="0" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock x:Name="AutoAssignedLabel" FontSize="12" Opacity="0.7"/>
                                        <TextBlock x:Name="AutoAssignedCount" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock x:Name="NeedsAttentionLabel" FontSize="12" Opacity="0.7"/>
                                        <TextBlock x:Name="NeedsAttentionCount" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="3" x:Name="StartScanButton" Click="StartScanButton_Click" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="16"/>
                                    <TextBlock x:Name="StartScanButtonText"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Conflicts Panel -->
                <Border x:Name="ConflictsPanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,2"
                        Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="ConflictsTitle" FontWeight="SemiBold" FontSize="14"/>

                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ConflictsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="12"
                                                Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="200"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="16" VerticalAlignment="Center" Opacity="0.7"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ModName}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding IssueDescription}" FontSize="11" Opacity="0.7" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="4">
                                                    <ComboBox ItemsSource="{Binding AvailableCategories}"
                                                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                                              PlaceholderText="Select category..."
                                                              HorizontalAlignment="Stretch"/>
                                                    <CheckBox Content="Overwrite"
                                                              IsChecked="{Binding ShouldOverwrite, Mode=TwoWay}"
                                                              Visibility="{Binding IsDuplicate}"
                                                              FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Resolve & Import Button -->
                <Border x:Name="ResolvePanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,24"
                        Visibility="Collapsed">
                    <Button x:Name="ResolveAndImportButton" Click="ResolveAndImportButton_Click" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" FontSize="16"/>
                            <TextBlock x:Name="ResolveAndImportButtonText"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Progress Card -->
                <Border x:Name="ProgressPanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,2"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8B5;" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="8">
                            <TextBlock x:Name="ProgressTitle" FontWeight="SemiBold" FontSize="14"/>
                            <ProgressBar x:Name="ImportProgressBar" IsIndeterminate="False" Maximum="100" Value="0"/>
                            <TextBlock x:Name="ProgressStatus" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

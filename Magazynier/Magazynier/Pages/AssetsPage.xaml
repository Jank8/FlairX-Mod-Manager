<Page
    x:Class="Magazynier.Pages.AssetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PageTitle" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="AddButton" Grid.Column="1" Style="{StaticResource AccentButtonStyle}"
                    Click="AddButton_Click" Height="36">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock x:Name="AddButtonText"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="SearchBox"
                            Grid.Column="0"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted"/>
            <ComboBox x:Name="CategoryFilter"
                      Grid.Column="2"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="CategoryFilter_SelectionChanged"/>
            <ComboBox x:Name="StatusFilter"
                      Grid.Column="4"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="StatusFilter_SelectionChanged"/>
        </Grid>

        <!-- Assets List -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <ListView x:Name="AssetsList"
                          Padding="0"
                          SelectionMode="Single"
                          SelectionChanged="AssetsList_SelectionChanged">
                    <ListView.Header>
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColName" Grid.Column="0" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColSerial" Grid.Column="1" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColCategory" Grid.Column="2" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColManufacturer" Grid.Column="3" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColAssignedTo" Grid.Column="4" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColDecision" Grid.Column="5" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColStatus" Grid.Column="6" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock Grid.Column="7" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="16,8" MinHeight="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding InventoryNumber}" FontSize="11" Opacity="0.5"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding SerialNumber}"
                                           VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                                <TextBlock Grid.Column="2" Text="{Binding CategoryName}"
                                           VerticalAlignment="Center" FontSize="12"/>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Manufacturer}" FontSize="12"/>
                                    <TextBlock Text="{Binding Model}" FontSize="11" Opacity="0.6"/>
                                </StackPanel>
                                <TextBlock Grid.Column="4" Text="{Binding AssignedUserName}"
                                           VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Grid.Column="5" Text="{Binding AssignmentDecisionNumber}"
                                           VerticalAlignment="Center" FontSize="12"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <Border Grid.Column="6" VerticalAlignment="Center"
                                        CornerRadius="4" Padding="8,3"
                                        HorizontalAlignment="Left"
                                        Background="{Binding StatusBrush}">
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                               Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <StackPanel Grid.Column="7" Orientation="Horizontal"
                                            Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Tag="{Binding}"
                                            Width="32" Height="32" Padding="0"
                                            Click="EditAsset_Click"
                                            ToolTipService.ToolTip="Edit">
                                        <FontIcon Glyph="&#xE70F;" FontSize="13"/>
                                    </Button>
                                    <Button Tag="{Binding}"
                                            Width="32" Height="32" Padding="0"
                                            Click="DeleteAsset_Click"
                                            ToolTipService.ToolTip="Delete">
                                        <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <FontIcon Glyph="&#xE7F4;" FontSize="48" Opacity="0.3"/>
                    <TextBlock x:Name="EmptyStateText" Opacity="0.5" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Asset detail / action panel (bottom) -->
        <Border x:Name="ActionPanel"
                Grid.Row="2"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,16,16"
                Padding="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="AssignButton" Style="{StaticResource AccentButtonStyle}"
                        Click="AssignButton_Click" Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8D7;" FontSize="14"/>
                        <TextBlock x:Name="AssignButtonText"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ReturnButton"
                        Click="ReturnButton_Click" Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                        <TextBlock x:Name="ReturnButtonText"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>

<Page
    x:Class="Magazynier.Pages.AssignmentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PageTitle" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <!-- Toggle active/history -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ToggleButton x:Name="ShowActiveToggle" IsChecked="True"
                              Checked="FilterToggle_Changed" Unchecked="FilterToggle_Changed"
                              Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8D7;" FontSize="14"/>
                        <TextBlock x:Name="ShowActiveText"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="ShowHistoryToggle" IsChecked="False"
                              Checked="FilterToggle_Changed" Unchecked="FilterToggle_Changed"
                              Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                        <TextBlock x:Name="ShowHistoryText"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- Search -->
        <AutoSuggestBox x:Name="SearchBox"
                        Grid.Row="1"
                        QueryIcon="Find"
                        Margin="0,0,0,12"
                        TextChanged="SearchBox_TextChanged"/>

        <!-- Assignments List -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <ListView x:Name="AssignmentsList" SelectionMode="None">
                    <ListView.Header>
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColAsset" Grid.Column="0" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColUser" Grid.Column="1" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColDecision" Grid.Column="2" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColAssignedAt" Grid.Column="3" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="ColReturnedAt" Grid.Column="4" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                                <TextBlock Grid.Column="5" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                            </Grid>
                        </Border>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="16,8" MinHeight="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AssetName}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding AssetSerial}" FontSize="11" Opacity="0.5"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding UserName}"
                                           VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Grid.Column="2" Text="{Binding DecisionNumber}"
                                           VerticalAlignment="Center" FontSize="12"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="{Binding AssignedAtFormatted}"
                                           VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="{Binding ReturnedAtFormatted}"
                                           VerticalAlignment="Center" FontSize="12" Opacity="0.7"/>
                                <Button Grid.Column="5" Tag="{Binding}"
                                        Width="32" Height="32" Padding="0"
                                        Visibility="{Binding ReturnButtonVisibility}"
                                        Click="ReturnAsset_Click"
                                        ToolTipService.ToolTip="Return">
                                    <FontIcon Glyph="&#xE72B;" FontSize="13"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE8D7;" FontSize="48" Opacity="0.3"/>
                    <TextBlock x:Name="EmptyStateText" Opacity="0.5" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

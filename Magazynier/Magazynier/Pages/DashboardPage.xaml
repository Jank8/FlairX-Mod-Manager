<Page
    x:Class="Magazynier.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="8*" MaxWidth="1100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Spacing="16">

                <!-- Page Title -->
                <TextBlock x:Name="PageTitle" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>

                <!-- Stats Cards Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total -->
                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE7F4;" FontSize="24" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="StatTotal" Text="0" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="StatTotalLabel" FontSize="12" HorizontalAlignment="Center"
                                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Available -->
                    <Border Grid.Column="2"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE73E;" FontSize="24" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource StatusBadgeAvailableBrush}"/>
                            <TextBlock x:Name="StatAvailable" Text="0" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource StatusBadgeAvailableBrush}"/>
                            <TextBlock x:Name="StatAvailableLabel" FontSize="12" HorizontalAlignment="Center"
                                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Assigned -->
                    <Border Grid.Column="4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE8D7;" FontSize="24" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource StatusBadgeAssignedBrush}"/>
                            <TextBlock x:Name="StatAssigned" Text="0" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource StatusBadgeAssignedBrush}"/>
                            <TextBlock x:Name="StatAssignedLabel" FontSize="12" HorizontalAlignment="Center"
                                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- In Repair -->
                    <Border Grid.Column="6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE90F;" FontSize="24" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource StatusBadgeRepairBrush}"/>
                            <TextBlock x:Name="StatInRepair" Text="0" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource StatusBadgeRepairBrush}"/>
                            <TextBlock x:Name="StatInRepairLabel" FontSize="12" HorizontalAlignment="Center"
                                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Retired -->
                    <Border Grid.Column="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE7C3;" FontSize="24" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource StatusBadgeRetiredBrush}"/>
                            <TextBlock x:Name="StatRetired" Text="0" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource StatusBadgeRetiredBrush}"/>
                            <TextBlock x:Name="StatRetiredLabel" FontSize="12" HorizontalAlignment="Center"
                                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Recent Assignments -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="RecentAssignmentsTitle" FontSize="16" FontWeight="SemiBold"/>
                        <ListView x:Name="RecentAssignmentsList"
                                  MaxHeight="320"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding AssetName}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding AssetSerial}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding UserName}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DecisionNumber}" FontSize="12"
                                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{Binding AssignedAtFormatted}" FontSize="11" Opacity="0.6"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:Name="NoRecentText" Visibility="Collapsed"
                                   Opacity="0.5" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
